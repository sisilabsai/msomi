# ─── AI Keys ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
AI_PROVIDER=anthropic          # anthropic | openai

# ─── Data Feeds ───────────────────────────────────────────────────────────────
TWELVE_DATA_API_KEY=414f4f6db62d44b791395bb8528d03a4
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/msomi.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/msomi

# ─── Account ──────────────────────────────────────────────────────────────────
ACCOUNT_BALANCE=1000.0
ACCOUNT_CURRENCY=USD

# ─── Risk Defaults ────────────────────────────────────────────────────────────
RISK_PER_TRADE=0.02            # 2% of balance
DAILY_LOSS_LIMIT=0.10          # 10% of balance
MAX_CONSECUTIVE_LOSSES=3

# ─── App ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENV=development
